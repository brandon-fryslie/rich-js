{
  "name": "rich-js",
  "version": "0.0.1",
  "description": "Rich text and beautiful formatting in the terminal — a TypeScript port of Python's Rich",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./themes/data": {
      "types": "./dist/themes/data/index.d.ts",
      "import": "./dist/themes/data/index.js"
    },
    "./themes/registry": {
      "types": "./dist/themes/registry.d.ts",
      "import": "./dist/themes/registry.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "demo": "tsc -p tsconfig.demo.json && node dist-demo/examples/rich-explore/index.js",
    "demo:build": "tsc -p tsconfig.demo.json",
    "sessions": "tsc -p tsconfig.demo.json && node dist-demo/examples/claude-sessions/index.js",
    "colors": "tsc -p tsconfig.demo.json && node dist-demo/examples/rich-colors/index.js",
    "strip": "tsc -p tsconfig.demo.json && node dist-demo/examples/rich-strip/index.js",
    "markup-plugins": "tsc -p tsconfig.demo.json && node dist-demo/examples/rich-markup-plugins/index.js",
    "dash": "tsc -p tsconfig.demo.json && node dist-demo/examples/rich-dash/index.js"
  },
  "keywords": [
    "terminal",
    "rich",
    "ansi",
    "color",
    "table",
    "panel",
    "tree",
    "syntax",
    "markdown",
    "progress",
    "cli"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.7.0",
    "vitepress": "^1.6.4",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "mobx": "^6.15.0",
    "string-width": "^8.2.0",
    "strip-ansi": "^7.2.0"
  }
}
